# Copie este arquivo para .env e preencha os valores

# === DATABRICKS ===
# Token de service account (nĂŁo usar OAuth pessoal em produĂ§ĂŁo)
DATABRICKS_TOKEN=dapi_SEU_SERVICE_ACCOUNT_TOKEN_AQUI
DATABRICKS_HOST=https://picpay-principal.cloud.databricks.com
DATABRICKS_WAREHOUSE_ID=6077a99f149e0d70

# === APLICAĂĂO ===
# Porta do servidor
PORT=8080

# Chave secreta Flask (gere com: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=gere_uma_chave_segura_aqui

# VersĂŁo da aplicaĂ§ĂŁo
APP_VERSION=22

# === OPERADORES ===
# Lista de operadores conhecidos (JSON) â opcional, pode deixar vazio
# Exemplo: {"Cesar": "cesar.oda@picpay.com", "Deyvis": "deyvis.balconi@picpay.com"}
OPERADORES_JSON=

# === SMTP (E-MAIL) ===
# ConfiguraĂ§Ăľes de email para envio das cotaĂ§Ăľes
# Pode ser configurado pela interface tambĂŠm
SMTP_USER=
SMTP_PASS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_DISPLAY_NAME=PicPay AR
